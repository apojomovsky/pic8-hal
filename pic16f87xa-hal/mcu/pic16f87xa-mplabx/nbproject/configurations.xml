<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://www.netbeans.org/ns/project/1">
    <type>com.microchip.mplabxide.projects.standalone</type>
    <configuration>
        <data xmlns="http://www.netbeans.org/ns/make-project-private/1">
            <name>pic16f87xa-firmware</name>
            <creators>
                <item>pic16f87xa-hal</item>
            </creators>
            <make-deps-projects/>
            <source-root>${project_dir}/../../..</source-root>
        </data>
    </configuration>
    <folders>
        <logical-folder id="HeaderFiles" name="Header Files" pattern="(?i).*\.h$"/>
        <logical-folder id="SourceFiles" name="Source Files" pattern="(?i).*\.c$"/>
    </folders>
    <configuration id="xc8_2.40" name="XC8 v2.40">
        <toolchain>com.microchip.mplabxcore.toolchainXC8</toolchain>
        <platform>com.microchip.mplabxcore.platforms.pic16</platform>
        <language>com.microchip.mplabxcore.langXC8C</language>
        <device>com.microchip.mplabxcore.devices.PIC$(MCU_PART)</device>
        <root dir="../.."/>
        <files id="xc8_2.40.">
            <logical-folder name="Header Files" path="include">
                <item path="include/pic16f87xa.h"/>
                <item path="include/pic16f87xa_sfr.h"/>
                <item path="include/pic16f87xa_sim.h"/>
                <item path="include/core/pic16f87xa_interrupt.h"/>
                <item path="include/core/pic16f87xa_wdt_sleep.h"/>
                <item path="include/peripherals/pic16f87xa_gpio.h"/>
                <item path="include/peripherals/pic16f87xa_timer0.h"/>
                <item path="include/peripherals/pic16f87xa_timer1.h"/>
                <item path="include/peripherals/pic16f87xa_timer2.h"/>
                <item path="include/peripherals/pic16f87xa_ccp.h"/>
                <item path="include/peripherals/pic16f87xa_usart.h"/>
                <item path="include/peripherals/pic16f87xa_ssp.h"/>
                <item path="include/peripherals/pic16f87xa_adc.h"/>
                <item path="include/peripherals/pic16f87xa_comp.h"/>
                <item path="include/peripherals/pic16f87xa_vref.h"/>
                <item path="include/peripherals/pic16f87xa_eeprom.h"/>
                <item path="include/peripherals/pic16f87xa_psp.h"/>
            </logical-folder>
            <logical-folder name="Source Files" path="src">
                <item path="src/core/pic16f87xa_interrupt.c"/>
                <item path="src/core/pic16f87xa_wdt_sleep.c"/>
                <item path="src/peripherals/pic16f87xa_gpio.c"/>
                <item path="src/peripherals/pic16f87xa_timer0.c"/>
                <item path="src/peripherals/pic16f87xa_timer1.c"/>
                <item path="src/peripherals/pic16f87xa_timer2.c"/>
                <item path="src/peripherals/pic16f87xa_ccp.c"/>
                <item path="src/peripherals/pic16f87xa_usart.c"/>
                <item path="src/peripherals/pic16f87xa_ssp.c"/>
                <item path="src/peripherals/pic16f87xa_adc.c"/>
                <item path="src/peripherals/pic16f87xa_comp.c"/>
                <item path="src/peripherals/pic16f87xa_vref.c"/>
                <item path="src/peripherals/pic16f87xa_eeprom.c"/>
                <item path="src/peripherals/pic16f87xa_psp.c"/>
            </logical-folder>
            <logical-folder name="Application" path="app">
                <item path="../../tests/example_blink.c"/>
            </logical-folder>
        </files>
        <properties>
            <property key="XC8-asmlist" value="true"/>
            <property key="XC8-codecov" value="false"/>
            <property key="XC8-elf" value="true"/>
            <property key="XC8-hex" value="true"/>
            <property key="XC8-obj" value="true"/>
            <property key="XC8-optsize" value="false"/>
            <property key="XC8-stack" value="auto"/>
            <property key="XC8-strconst" value="ROM"/>
            <property key="XC8-strict" value="false"/>
        </properties>
        <device-tree>
            <property key="xc8-cc-define" value="FOSC_HZ=20000000"/>
            <property key="xc8-cc-define" value="PIC$(MCU_PART)"/>
        </device-tree>
    </configuration>
</project>
