# Starter config for `git clang-format` (manual, opt-in use only, see
# scripts/README.md). NOT wired into the pre-commit hook: tested against
# real files in this repo (pic8-pid/src/pid.c) and it still reformats
# deliberate hand-tuned style this codebase relies on, aligned struct-field
# comments, single-line `if (x) { y; }` clamp idioms, `} else {` spacing,
# even collapsing a one-line function body onto its signature. Fix those
# before trusting this for anything other than a manual, reviewed
# `git clang-format --diff` look.
BasedOnStyle: LLVM
IndentWidth: 4
ColumnLimit: 80
BreakBeforeBraces: Stroustrup
AlignConsecutiveDeclarations: false
AlignConsecutiveAssignments: false
SpaceBeforeParens: ControlStatements
PointerAlignment: Right
IndentCaseLabels: true
