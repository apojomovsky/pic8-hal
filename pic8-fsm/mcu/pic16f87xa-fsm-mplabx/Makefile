# pic8-fsm, MPLAB XC8 Makefile -- PIC16F87XA cross-compile sanity check.
#
# fsm.c has no hardware dependency and no per-family variant (see
# docs/pic8-fsm-plan.md): correctness is already fully proven by the host
# suite (../../tests/test_fsm.c), which tests the exact same source file
# this Makefile compiles. This build exists only to (a) catch any
# accidentally non-portable C the host compiler let through, and (b) report
# real flash/RAM footprint on the smallest-RAM part in the family
# (PIC16F873A, 192 B RAM) via `make size`. No HAL, no config word beyond
# XC8's own defaults, no interrupt vector — target_sizecheck.c is a
# deliberately minimal standalone program, not firmware meant to be flashed.
#
#   export PATH=$PATH:/opt/microchip/xc8/v3.10/bin
#   make MCU=16F877A            # default; also 873A / 874A / 876A
#   make size
#   make clean

MCU     ?= 16F877A

ifeq ($(MCU),16F873A)
  CFLAGS_DEVICE := -DPIC16F873A
else ifeq ($(MCU),16F874A)
  CFLAGS_DEVICE := -DPIC16F874A
else ifeq ($(MCU),16F876A)
  CFLAGS_DEVICE := -DPIC16F876A
else ifeq ($(MCU),16F877A)
  CFLAGS_DEVICE := -DPIC16F877A
else
  $(error Unsupported MCU=$(MCU); choose 873A, 874A, 876A or 877A)
endif

APP_DIR   ?= ../..
BUILD_DIR ?= build
TARGET    := $(BUILD_DIR)/$(MCU)-fsm-sizecheck

DFP_DIR ?= /opt/microchip/xc8/v3.10/pic/packs/Microchip.PIC16Fxxx_DFP/xc8
ifneq ($(strip $(DFP_DIR)),)
  DFP_FLAG := -mdfp=$(DFP_DIR)
else
  DFP_FLAG :=
endif

CC     := xc8-cc
INC    := -I$(APP_DIR)/include
CFLAGS := $(DFP_FLAG) -mcpu=$(shell echo $(MCU) | tr A-Z a-z) \
          -O2 -std=c99 -Wall -Wextra $(CFLAGS_DEVICE) $(INC)

SRCS  := $(APP_DIR)/src/fsm.c $(APP_DIR)/mcu/target_sizecheck.c
OBJS  := $(patsubst %.c,$(BUILD_DIR)/%.p1,$(notdir $(SRCS)))
VPATH := $(sort $(dir $(SRCS)))

.PHONY: all size clean
all: $(TARGET).hex

$(BUILD_DIR):
	mkdir -p $@

$(BUILD_DIR)/%.p1: %.c | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(TARGET).hex: $(OBJS)
	$(CC) $(CFLAGS) $(OBJS) -o $@ -ginhx32

size: $(TARGET).hex

clean:
	rm -rf $(BUILD_DIR)
